{
  "name": "disguise-remote-cue",
  "version": "1.0.0",
  "private": true,
  "description": "Tray app wrapper for disguise remote cue",
  "main": "desktop/main.cjs",
  "executableName": "disguise remote cue",
  "scripts": {
    "frontend:build": "npm --prefix frontend run build",
    "start": "electron .",
    "dist": "npm run frontend:build && electron-builder --win nsis --publish never",
    "pack": "npm run frontend:build && electron-builder --dir"
  },
  "devDependencies": {
    "electron": "^38.0.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "remote.disguise.cue",
    "productName": "disguise remote cue",
    "asar": false,
    "icon": "assets/app-icon.ico",
    "files": [
      "assets/**/*",
      "backend/**/*",
      "desktop/**/*",
      "frontend/dist/**/*"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "artifactName": "disguise-remote-cue-setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "installerIcon": "assets/app-icon.ico",
      "uninstallerIcon": "assets/app-icon.ico",
      "installerHeaderIcon": "assets/app-icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "menuCategory": "disguise remote cue",
      "shortcutName": "disguise remote cue"
    }
  }
}
